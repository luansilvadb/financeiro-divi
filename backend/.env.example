# Exemplo de configuração de ambiente para o Backend

# URL de conexão com o banco de dados PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/financeiro_divi?schema=public"

# Chave secreta para assinatura dos tokens JWT
JWT_SECRET="insira-uma-chave-secreta-aqui"

# Configurações de E-mail (SMTP)
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="[EMAIL_ADDRESS]"
SMTP_PASS="F5t78f00"

# URL do Frontend (usado para gerar links em e-mails, ex: recuperação de senha).
FRONTEND_URL="http://localhost:5173"

# ID do Cliente do Google OAuth (deve ser o mesmo do frontend)
GOOGLE_CLIENT_ID="insira-seu-google-client-id-aqui.apps.googleusercontent.com"

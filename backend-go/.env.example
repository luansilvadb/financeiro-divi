# ─────────────────────────────────────────────────────────────────────────────
# DIVI Backend — Variáveis de Ambiente
# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA comite o arquivo .env no repositório (já está no .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ─────────────────────────────────────────────────────────────────
# Porta em que o servidor HTTP irá escutar (default: 3000)
PORT=3000

# ── Banco de Dados ───────────────────────────────────────────────────────────
# URL de conexão PostgreSQL (formato: postgres://usuario:senha@host:porta/db)
DATABASE_URL="postgres://USUARIO:SENHA@localhost:5432/divi_go"

# ── JWT ─────────────────────────────────────────────────────────────────────
# Chave secreta para assinatura de tokens JWT (HS256)
# Gere com: openssl rand -base64 32
JWT_SECRET="<gere-uma-chave-forte-com-openssl-rand-base64-32>"

# Expiração do token JWT em horas (default: 24)
JWT_EXPIRY_HOURS=24

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas para CORS (separadas por vírgula)
# Em produção: https://seu-dominio.com
# Em desenvolvimento: http://localhost:5173
CORS_ORIGINS="http://localhost:5173"

# URL do frontend (usada para links em emails e CORS fallback)
FRONTEND_URL="http://localhost:5173"

# ── SMTP (Email) ─────────────────────────────────────────────────────────────
# Configuração para envio de emails transacionais (recuperação de senha, etc.)
SMTP_HOST="smtp.zoho.com"
SMTP_PORT=587
SMTP_USER="seu-email@exemplo.com"
SMTP_PASS="sua-senha-de-app"
SMTP_USE_TLS=true

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Client ID obtido no Google Cloud Console
GOOGLE_CLIENT_ID="seu-google-client-id.apps.googleusercontent.com"

# ── TLS / HTTPS (opcional) ───────────────────────────────────────────────────
# Caminhos para certificado e chave TLS (deixe vazio para HTTP)
TLS_CERT_FILE=""
TLS_KEY_FILE=""

# ── Swagger (documentação da API) ────────────────────────────────────────────
# Habilita a interface Swagger em /swagger/index.html
# true = habilitado (dev), false = desabilitado (produção)
SWAGGER_ENABLED=false

# ── Modo de execução ─────────────────────────────────────────────────────────
# "debug" para desenvolvimento, "release" para produção
# Controla sanitização de mensagens de erro, logging, etc.
GIN_MODE=debug

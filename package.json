    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "lucide-vue-next": "^1.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.2.8"
